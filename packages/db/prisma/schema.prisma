generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  email              String              @unique
  password           String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  credits            Int                 @default(1000)
  id                 Int                 @id @default(autoincrement())
  apiKeys            ApiKey[]
  conversations      Conversation[]
  onrampTransactions OnrampTransaction[]
  requestLogs        RequestLog[]
  memories           Memory[]
}

model ApiKey {
  name            String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  apiKey          String         @unique
  creditsConsumed Int            @default(0)
  lastUsed        DateTime?
  deleted         Boolean        @default(false)
  disabled        Boolean        @default(false)
  id              Int            @id @default(autoincrement())
  userId          Int
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  requestLogs     RequestLog[]
  memories           Memory[]
}

model Company {
  name      String   @unique
  website   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  id        Int      @id @default(autoincrement())
  models    Model[]
}

model Model {
  name                  String                 @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  slug                  String                 @unique
  id                    Int                    @id @default(autoincrement())
  companyId             Int
  company               Company                @relation(fields: [companyId], references: [id])
  modelProviderMappings ModelProviderMapping[]
}

model Provider {
  name                  String                 @unique
  website               String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  id                    Int                    @id @default(autoincrement())
  modelProviderMappings ModelProviderMapping[]
}

model ModelProviderMapping {
  inputTokenCost  Int
  outputTokenCost Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  id              Int            @id @default(autoincrement())
  modelId         Int
  providerId      Int
  conversations   Conversation[]
  model           Model          @relation(fields: [modelId], references: [id])
  provider        Provider       @relation(fields: [providerId], references: [id])
}

model OnrampTransaction {
  amount    Int
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  conversationId         String               @unique
  input                  String
  output                 String
  inputTokenCount        Int
  outputTokenCount       Int
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  apiKeyId               Int
  id                     Int                  @id @default(autoincrement())
  userId                 Int
  modelProviderMappingId Int
  apiKey                 ApiKey               @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  modelProviderMapping   ModelProviderMapping @relation(fields: [modelProviderMappingId], references: [id])
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RequestLog {
  id              Int                 @id @default(autoincrement())
  userId          Int
  apiKeyId        Int
  model           String
  provider        String?
  status          RequestLogStatus
  errorType       RequestLogErrorType?
  fallbackUsed    Boolean             @default(false)
  fallbackCount   Int                 @default(1)
  promptTokens    Int                 @default(0)
  completionTokens Int                @default(0)
  totalTokens     Int                 @default(0)
  cost            Int                 @default(0)
  streaming       Boolean             @default(false)
  latencyMs       Int
  ttftMs          Int?
  injectedMemories Json?
  memoryCount     Int                 @default(0)
  memoryInjected  Int                 @default(0)
  cachedInputTokens Int               @default(0)
  regularInputTokens Int              @default(0)
  baseCost        Int                 @default(0)
  memoryCost      Int                 @default(0)
  cachedSavings   Int                 @default(0)
  costBreakdown   Json?
  createdAt       DateTime            @default(now())

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey          ApiKey              @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([model, createdAt])
  @@index([provider, createdAt])
}

model Memory {
  id Int @id @default(autoincrement())
  userId Int
  apiKeyId Int?
  scope MemoryScope @default(user)
  content     String
  embedding   Unsupported("vector")?
  source      String?
  savedBy     MemorySavedBy @default(manual)
  reasoning   String?
  confidence  Float       @default(0.5)
  importance  Float       @default(0.5)
  compressedFrom Json?
  compressedIntoId Int?
  isCompressed Boolean    @default(false)
  enabled     Boolean     @default(true)
  archived    Boolean     @default(false)
  archivedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lastUsedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId, enabled, archived])
  @@index([userId, archivedAt])
  @@index([userId, scope])
  @@index([userId, lastUsedAt])
  @@index([userId, isCompressed])

}

enum RequestLogStatus {
  success
  error
  rate_limited
}

enum RequestLogErrorType {
  timeout
  provider_5xx
  invalid_request
  rate_limit
  other
}

enum MemoryScope {
  conversation
  user
  project
  semantic
}

enum MemorySavedBy {
  manual
  rule
  llm
  compression
}
