generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  email              String              @unique
  password           String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  credits            Int                 @default(1000)
  plan               UserPlan            @default(free)
  id                 Int                 @id @default(autoincrement())
  apiKeys            ApiKey[]
  conversations      Conversation[]
  onrampTransactions OnrampTransaction[]
  requestLogs        RequestLog[]
  memories           Memory[]
  mcpServers         McpServer[]
  mcpToolExecutions  McpToolExecution[]
}

model ApiKey {
  name            String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  apiKey          String         @unique
  creditsConsumed Int            @default(0)
  lastUsed        DateTime?
  deleted         Boolean        @default(false)
  disabled        Boolean        @default(false)
  id              Int            @id @default(autoincrement())
  userId          Int
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  requestLogs     RequestLog[]
  memories           Memory[]
  mcpToolLinks     McpApiKeyTool[]
  mcpToolExecutions McpToolExecution[]
}

model Company {
  name      String   @unique
  website   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  id        Int      @id @default(autoincrement())
  models    Model[]
}

model Model {
  name                  String                 @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  slug                  String                 @unique
  minPlan               UserPlan               @default(free)
  id                    Int                    @id @default(autoincrement())
  companyId             Int
  company               Company                @relation(fields: [companyId], references: [id])
  modelProviderMappings ModelProviderMapping[]
}

model Provider {
  name                  String                 @unique
  website               String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  id                    Int                    @id @default(autoincrement())
  modelProviderMappings ModelProviderMapping[]
}

model ModelProviderMapping {
  inputTokenCostNanoDollars  Int
  outputTokenCostNanoDollars Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  id              Int            @id @default(autoincrement())
  modelId         Int
  providerId      Int
  conversations   Conversation[]
  model           Model          @relation(fields: [modelId], references: [id])
  provider        Provider       @relation(fields: [providerId], references: [id])
}

model OnrampTransaction {
  amount                  Int
  status                  String
  provider                String?
  providerSessionId       String? @unique
  providerPaymentIntentId String?
  packageId               String?
  type                    String  @default("credits")
  metadata                Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  id                      Int      @id @default(autoincrement())
  userId                  Int
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  conversationId         String               @unique
  input                  String
  output                 String
  inputTokenCount        Int
  outputTokenCount       Int
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  apiKeyId               Int
  id                     Int                  @id @default(autoincrement())
  userId                 Int
  modelProviderMappingId Int
  apiKey                 ApiKey               @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  modelProviderMapping   ModelProviderMapping @relation(fields: [modelProviderMappingId], references: [id])
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RequestLog {
  id              Int                 @id @default(autoincrement())
  userId          Int
  apiKeyId        Int
  model           String
  provider        String?
  status          RequestLogStatus
  errorType       RequestLogErrorType?
  fallbackUsed    Boolean             @default(false)
  fallbackCount   Int                 @default(1)
  promptTokens    Int                 @default(0)
  completionTokens Int                @default(0)
  totalTokens     Int                 @default(0)
  cost            Int                 @default(0)
  streaming       Boolean             @default(false)
  latencyMs       Int
  ttftMs          Int?
  injectedMemories Json?
  memoryCount     Int                 @default(0)
  memoryInjected  Int                 @default(0)
  cachedInputTokens Int               @default(0)
  regularInputTokens Int              @default(0)
  baseCost        Int                 @default(0)
  memoryCost      Int                 @default(0)
  cachedSavings   Int                 @default(0)
  costBreakdown   Json?
  createdAt       DateTime            @default(now())

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey          ApiKey              @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([model, createdAt])
  @@index([provider, createdAt])
}

model Memory {
  id Int @id @default(autoincrement())
  userId Int
  apiKeyId Int?
  scope MemoryScope @default(user)
  content     String
  embedding   Unsupported("vector")?
  source      String?
  savedBy     MemorySavedBy @default(manual)
  reasoning   String?
  confidence  Float       @default(0.5)
  importance  Float       @default(0.5)
  compressedFrom Json?
  compressedIntoId Int?
  isCompressed Boolean    @default(false)
  enabled     Boolean     @default(true)
  archived    Boolean     @default(false)
  archivedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lastUsedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId, enabled, archived])
  @@index([userId, archivedAt])
  @@index([userId, scope])
  @@index([userId, lastUsedAt])
  @@index([userId, isCompressed])

}

model McpServer {
  id               Int                @id @default(autoincrement())
  userId           Int
  name             String
  command          String
  args             Json?
  env              Json?
  enabled          Boolean            @default(true)
  lastDiscoveredAt DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tools            McpTool[]
  executions       McpToolExecution[]

  @@index([userId, enabled])
}

model McpTool {
  id          Int             @id @default(autoincrement())
  serverId    Int
  name        String
  description String?
  inputSchema Json?
  embedding   Unsupported("vector")?
  enabled     Boolean         @default(true)
  lastSeenAt  DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  server      McpServer       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  apiKeyLinks McpApiKeyTool[]
  executions  McpToolExecution[]

  @@unique([serverId, name])
  @@index([serverId, enabled])
}

model McpApiKeyTool {
  id        Int      @id @default(autoincrement())
  apiKeyId  Int
  toolId    Int
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  tool      McpTool  @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, toolId])
  @@index([toolId, enabled])
}

model McpToolExecution {
  id        Int                    @id @default(autoincrement())
  userId    Int
  apiKeyId  Int?
  serverId  Int
  toolId    Int?
  toolName  String
  status    McpToolExecutionStatus
  input     Json?
  output    Json?
  error     String?
  latencyMs Int
  createdAt DateTime               @default(now())

  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey    ApiKey?                @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  server    McpServer              @relation(fields: [serverId], references: [id], onDelete: Cascade)
  tool      McpTool?               @relation(fields: [toolId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([serverId, createdAt])
  @@index([toolId, createdAt])
}

enum RequestLogStatus {
  success
  error
  rate_limited
}

enum RequestLogErrorType {
  timeout
  provider_5xx
  invalid_request
  rate_limit
  other
}

enum MemoryScope {
  conversation
  user
  project
  semantic
}

enum MemorySavedBy {
  manual
  rule
  llm
  compression
}

enum McpToolExecutionStatus {
  success
  error
}

enum UserPlan {
  free
  pro
}
